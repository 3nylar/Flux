# ---------------------------------------------------------------------------
# Flux API — environment configuration
# Copy to .env for local development, or set these in your hosting
# provider's dashboard for production.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=8081
HOST=0.0.0.0
LOG_LEVEL=info
PUBLIC_BASE_URL=http://localhost:8081

# Postgres. Required -- see docs/DATABASE.md for why SQLite isn't an option
# here (same reasoning as Flux's sibling projects: this is server
# infrastructure meant for real hosting).
DATABASE_URL=postgresql://flux:flux@localhost:5433/flux

# --- Lightning backend -------------------------------------------------
# "simulated" (default): zero infrastructure, fully working, fake payments.
# "lnd": real keysend payments via a real LND node's REST API.
LIGHTNING_PROVIDER=simulated

# Simulated-provider tuning (only used when LIGHTNING_PROVIDER=simulated).
# Set SIM_FAILURE_RATE above 0 to exercise the circuit breaker / DEGRADED
# state without needing to actually break a real node's connectivity.
SIM_FAILURE_RATE=0
SIM_LATENCY_MS=150

# Required only when LIGHTNING_PROVIDER=lnd. See docs/LND_INTEGRATION.md.
LND_REST_URL=
LND_MACAROON_HEX=
LND_TLS_CERT_BASE64=

# --- Safety ceilings -----------------------------------------------------
# Enforced server-side regardless of what a client requests.
MAX_SESSION_DURATION_SECONDS=21600
MAX_TOTAL_SATS_PER_SESSION=1000000
MIN_TICK_INTERVAL_SECONDS=1
MAX_CONSECUTIVE_PAYMENT_FAILURES=3
STALE_SESSION_TIMEOUT_SECONDS=120

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
